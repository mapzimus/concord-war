      "source": "osm",
      "paint": {
        "raster-saturation": -0.9,
        "raster-contrast": 0.05,
        "raster-brightness-min": 0.25,
        "raster-brightness-max": 0.95,
        "raster-opacity": 0.55
      }
    }
  ]
}
