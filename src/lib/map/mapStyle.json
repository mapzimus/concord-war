{
  "version": 8,
  "name": "concord-war-sepia",
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "omt": { "type": "vector", "url": "https://tiles.openfreemap.org/planet", "attribution": "© OpenFreeMap © OpenMapTiles © OpenStreetMap" }
  },
  "layers": [
    { "id": "bg", "type": "background", "paint": { "background-color": "#e7dcc0" } },
    { "id": "wood", "type": "fill", "source": "omt", "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "wood"],
      "paint": { "fill-color": "#d3cda6", "fill-opacity": 0.45 } },
    { "id": "park", "type": "fill", "source": "omt", "source-layer": "park",
      "paint": { "fill-color": "#d2cfa3", "fill-opacity": 0.4 } },
    { "id": "water", "type": "fill", "source": "omt", "source-layer": "water",
      "paint": { "fill-color": "#9fb4c2" } },
    { "id": "waterway", "type": "line", "source": "omt", "source-layer": "waterway",
      "paint": { "line-color": "#9fb4c2", "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.5, 14, 2] } },
    { "id": "buildings", "type": "fill", "source": "omt", "source-layer": "building", "minzoom": 13,
      "paint": { "fill-color": "#cdbd97", "fill-opacity": 0.55 } },
    { "id": "roads", "type": "line", "source": "omt", "source-layer": "transportation",
      "paint": { "line-color": "#c0aa78", "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.3, 12, 1.1, 16, 3] } },
    { "id": "roads-major", "type": "line", "source": "omt", "source-layer": "transportation",
      "filter": ["in", ["get", "class"], ["literal", ["motorway", "trunk", "primary"]]],
      "paint": { "line-color": "#a8843c", "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.8, 12, 2.4, 16, 6] } },
    { "id": "boundary", "type": "line", "source": "omt", "source-layer": "boundary",
      "filter": ["<=", ["get", "admin_level"], 6],
      "paint": { "line-color": "#7a6a4a", "line-width": 0.8, "line-dasharray": [3, 2], "line-opacity": 0.6 } },
    { "id": "place-labels", "type": "symbol", "source": "omt", "source-layer": "place",
      "filter": ["in", ["get", "class"], ["literal", ["city", "town", "village", "suburb", "neighbourhood"]]],
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 10, 13, 15],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.12
      },
      "paint": { "text-color": "#5a4a2a", "text-halo-color": "#e7dcc0", "text-halo-width": 1.6 } },
    { "id": "road-labels", "type": "symbol", "source": "omt", "source-layer": "transportation_name", "minzoom": 12,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11,
        "symbol-placement": "line"
      },
      "paint": { "text-color": "#7a6a4a", "text-halo-color": "#e7dcc0", "text-halo-width": 1.2 } }
  ]
}
